# Shifty server config — コピーして .env として使用 (もしくはホスティング側の env vars に登録)

# 初回起動時に自動セットアップされる管理者パスワード（未設定なら起動後の画面でセットアップ）
ADMIN_PASS=

# Flask セッションクッキー署名キー — 本番では必ずランダムな長文字列に
SECRET_KEY=change-this-to-random-string

# SQLite DB ファイルパス（書き込み可能な場所）
DATABASE_PATH=shifty.db

# 待ち受けポート（Render/Railway などはホスティング側が設定）
PORT=5173
